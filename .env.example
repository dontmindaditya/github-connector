# =============================================================================
# GitHub Connector — Environment Variables
# =============================================================================
# Copy this file to `.env` (local) or `.env.local` (Next.js convention) and
# fill in the values. NEVER commit the real .env — it's in .gitignore.
#
# All variables here are validated at boot by src/lib/env.ts. If any are
# missing or malformed, the server refuses to start with a clear error.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Works with any Postgres provider:
#   - Local:    postgresql://postgres:postgres@localhost:5432/github_connector
#   - Neon:     postgresql://user:pass@ep-xyz.neon.tech/dbname?sslmode=require
#   - Supabase: postgresql://postgres:pass@db.xyz.supabase.co:5432/postgres
#   - Vercel:   provided automatically when you add Vercel Postgres
#
# For serverless deploys (Vercel), add `?pgbouncer=true&connection_limit=1`
# if your provider supports pgbouncer — avoids exhausting connections.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/github_connector"


# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public URL of your deployment. Used to build redirect URLs in the OAuth
# flow and rendered in the dashboard. NO trailing slash.
#   - Local:      http://localhost:3000
#   - Vercel:     https://your-app.vercel.app
#   - Custom:     https://github-connector.yourdomain.com
APP_URL="http://localhost:3000"

NODE_ENV="development"


# -----------------------------------------------------------------------------
# GitHub App credentials
# -----------------------------------------------------------------------------
# Create your GitHub App at https://github.com/settings/apps/new
# (or for orgs: https://github.com/organizations/<org>/settings/apps/new).
# See docs/GITHUB_APP_SETUP.md for the full step-by-step.

# The numeric App ID, shown at the top of your App's settings page.
# Example: 123456
GITHUB_APP_ID="2852466"

# The URL slug of your App. If your App's public page is
# https://github.com/apps/my-connector  →  slug is "my-connector".
# This is used to build the install URL we redirect users to.
GITHUB_APP_SLUG="lifox-connector"

# OAuth Client ID, shown on the App settings page under "Client ID".
# Example: Iv1.abc123def456
GITHUB_CLIENT_ID="Iv23liwgagsjLW8CVHYl"

# OAuth Client Secret — generate one from the App settings page
# (button: "Generate a new client secret"). Shown ONCE at creation time.
GITHUB_CLIENT_SECRET="a7b3f464faa5587d82bc4a5631cbcbc666a951d2"

# The App's private key in PEM format. Download it from your App's
# settings page: "Private keys" → "Generate a private key" → saves a
# .pem file to disk.
#
# ⚠️ Two ways to format this value depending on where you host:
#
# 1. Local .env files (this file): paste the WHOLE PEM, newlines and all,
#    wrapped in double quotes. The shell will preserve them.
#
#    GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#    MIIEpAIBAAKCAQEA...
#    ...lots of lines...
#    -----END RSA PRIVATE KEY-----"
#
# 2. Vercel / most secret stores: they don't accept multi-line values, so
#    replace every real newline with the literal `\n` characters and paste
#    as a single line. The env loader at src/lib/env.ts restores them.
#
#    GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQ...\n...\n-----END RSA PRIVATE KEY-----\n"
#
# Quick conversion: `awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private-key.pem`
GITHUB_PRIVATE_KEY="SHA256:uU1A8SHAxxu/s0hUd3MQ4RZJ6xOzmM+N4JnNAuq/k9g="

# Webhook secret. You set this when configuring webhooks on the App, AND
# you set the same string here so we can verify X-Hub-Signature-256.
# Generate a strong random string:
#   openssl rand -hex 32
GITHUB_WEBHOOK_SECRET="71b255229f50bd1f479ae703baa092ac0aa2ad18095d2c585978c7453ea2da82"


# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Master key for AES-256-GCM. Must decode (from base64) to EXACTLY 32 bytes.
# Generate one with:
#
#   openssl rand -base64 32
#
# Rotating this key invalidates all cached installation tokens — they'll be
# re-minted on next use, which is fine. Existing webhook secrets and any
# other encrypted data will become undecryptable, so don't rotate without
# a migration plan.
ENCRYPTION_KEY="faTC5TPfty3pEGwQEea+NTbqzZCTVMw5XVjjJlqEbLs="


# =============================================================================
# Quick-start: paste these in your terminal to generate all the secrets
# =============================================================================
# echo "ENCRYPTION_KEY=$(openssl rand -base64 32)"
# echo "GITHUB_WEBHOOK_SECRET=$(openssl rand -hex 32)"
# =============================================================================